echo "🦥Running backend unit tests before pushing🦥"

cd backend
npm test

echo "Running check for vulnerabilities in the pipeline and fail if theres more than 3 before push"

vulnerabilities=$(npm audit --json | jq '.metadata.vulnerabilities.total')
echo "Found this many vunlnerabites: $vulnerabilities"
if [ "$vulnerabilities" -gt 3 ]; then
    echo "Too many vulnerabilities"
    exit 1
else 
    echo "Vulnerability count is fine"
fi









