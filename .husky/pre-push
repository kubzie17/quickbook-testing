#!/bin/sh

echo "running unit tests before push"
cd backend
npm test
cd ..

echo "running vulnerability check"

cd ..
npm audit || true
vuln_count=$(npm audit --json | jq '.metadata.vulnerabilities.moderate + .metadata.vulnerabilities.high')
echo "vulnerabilities found: $vuln_count"
if [ "$vuln_count" -gt 3 ]; then
  echo "vulnerability count ($vuln_count) exceeds threshold of 3"
  exit 1
fi
