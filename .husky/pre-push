echo "Checking for vulnerabilities before push"

npm audit --json > root-audit-report.json || true
high=$(jq '.metadata.vulnerabilities.high' root-audit-report.json)
moderate=$(jq '.metadata.vulnerabilities.moderate' root-audit-report.json)
low=$(jq '.metadata.vulnerabilities.low' root-audit-report.json)
vulnerabilities=$(jq '.metadata.vulnerabilities.total' root-audit-report.json)
echo "Total high vulnerabilities: $high"
echo "Total moderate vulnerabilities: $moderate"
echo "Total low vulnerabilities: $low"
echo "Total vulnerabilities: $vulnerabilities"

if [ "$vulnerabilities" -gt 3 ]; then
  echo "Vulnerability count exceeds threshold of 3."
  exit 1
else 
    echo "all is well"
fi

cd ../backend
npm test



