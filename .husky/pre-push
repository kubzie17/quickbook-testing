#!/bin/sh

echo "running vulnerability check"

cd ..
npm audit || true
vuln_count=$(npm audit --json | jq '.metadata.vulnerabilities.moderate + .metadata.vulnerabilities.high')
echo "vulnerabilities found: $vuln_count"
if [ "$vuln_count" -gt 2 ]; then
  echo "vulnerability count ($vuln_count) exceeds threshold of 2"
  exit 1
fi
