# ── PRE-PUSH HOOK ────────────────────────────────────────────
# Runs BEFORE code is pushed to the remote repository.
# This is your last line of defence before code leaves your machine.
# If any check fails, the push is blocked.

# 1. Run unit tests first
# Using a subshell (...) so the cd doesn't affect the rest of the script
echo "Running unit tests before commit..."
(cd backend && npm test)

# 2. Run security audit
# Checks all dependencies for known vulnerabilities (CVEs).
# Uses the same threshold logic as the CI pipeline.
# Critical/High = instant block. Moderate+Low = threshold of 3.

echo ""
echo "Running security audit before push..."

root_vulns=$(npm audit --json 2>/dev/null | jq '.metadata.vulnerabilities // {}')
back_vulns=$(cd backend && npm audit --json 2>/dev/null | jq '.metadata.vulnerabilities // {}')
front_vulns=$(cd frontend && npm audit --json 2>/dev/null | jq '.metadata.vulnerabilities // {}')

total_crit=$(echo "$root_vulns $back_vulns $front_vulns" | jq -s 'map(.critical // 0) | add')
total_high=$(echo "$root_vulns $back_vulns $front_vulns" | jq -s 'map(.high // 0) | add')
total_mod=$(echo "$root_vulns $back_vulns $front_vulns" | jq -s 'map(.moderate // 0) | add')
total_low=$(echo "$root_vulns $back_vulns $front_vulns" | jq -s 'map(.low // 0) | add')
total=$(( total_crit + total_high + total_mod + total_low ))

echo ""
echo "Security Audit: C:$total_crit H:$total_high M:$total_mod L:$total_low (total: $total, threshold: 2)"

if [ "$total_crit" -gt 0 ]; then
  echo "BLOCKED: Critical vulnerabilities found"
  exit 1
fi

if [ "$total_high" -gt 0 ]; then
  echo "BLOCKED: High vulnerabilities found"
  exit 1
fi

if [ "$total" -gt 3 ]; then
  echo "BLOCKED: $total vulnerabilities exceed threshold of 3"
  exit 1
fi

echo "Security audit passed"

# 3. Build frontend
# "npm run build" compiles the React app for production.
# This catches things that work in dev mode but break in production:
#   - Missing imports (dev mode is more forgiving)
#   - JSX syntax errors
#   - Environment variable issues
#   - Dead code that breaks when tree-shaken
# If it can't build here, it won't build in CI either.
echo ""
echo "Building frontend to check for syntax/build errors..."
(cd frontend && npm run build)

echo ""
echo "All pre-push checks passed"
