#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "Running npm audit check..."

# Run audit and capture output
npm audit --json > root-audit-report.json 2>&1 || true

# Extract vulnerability count (requires jq)
vulnerabilities=$(jq '.metadata.vulnerabilities.total' root-audit-report.json)
#vulnerabilities=$(node -e "console.log(require('./root-audit-report.json').metadata.vulnerabilities.total)")

echo "Total vulnerabilities: $vulnerabilities"

# Threshold check
if [ "$vulnerabilities" -gt 4 ]; then
  echo "($vulnerabilities) vulnerabilities found, exceeding threshold of 3. Push blocked."
  exit 1
else
  echo "Vulnerabilities are within acceptable limits: ($vulnerabilities) <= 3"
fi
#!/usr/bin/env sh
echo "Running backend unit tests..."
cd backend
npm test || exit 1

cd ../frontend
echo "Building frontend..."
npm run build || exit 1

cd ..
echo "All pre-push checks passed"